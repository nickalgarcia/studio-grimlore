rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    match /users/{userId}/campaigns/{campaignId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      // Deny all access to subcollections not explicitly matched below
      match /{allPaths=**} {
        allow read, write: if false;
      }
    }

    match /users/{userId}/campaigns/{campaignId}/characters/{characterId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.campaignId == campaignId;
      allow update: if isExistingOwner(userId) && request.resource.data.campaignId == campaignId;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/npcs/{npcId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/factions/{factionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/locations/{locationId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.campaignId == campaignId;
      allow update: if isExistingOwner(userId) && request.resource.data.campaignId == campaignId;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/sessions/{sessionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.campaignId == campaignId;
      allow update: if isExistingOwner(userId) && request.resource.data.campaignId == campaignId;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/concepts/{conceptId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/plotHooks/{plotHookId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/encounterIdeas/{encounterIdeaId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/campaigns/{campaignId}/npcConcepts/{npcConceptId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}